root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{js,css,html,json,yml,yaml,md}]
indent_size = 2

# Markdown can use two trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false
